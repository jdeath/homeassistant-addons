worker_processes 1;

events {
    worker_connections 512;
}

http {
    map $http_upgrade $connection_upgrade {
        default upgrade;
        ''      close;
    }

    # Direct access — ingress entry baked in at container startup
    server {
        listen 8082;

        location / {
            if ($uri !~* ^${INGRESS_ENTRY}) {
                rewrite ^(.*)$ ${INGRESS_ENTRY}$1 break;
            }
            proxy_pass          http://127.0.0.1:8081;
            proxy_http_version  1.1;
            proxy_set_header    Upgrade         $http_upgrade;
            proxy_set_header    Connection      $connection_upgrade;
            proxy_set_header    Host            $http_host;
            proxy_set_header    X-Real-IP       $remote_addr;
            proxy_set_header    X-Forwarded-For $proxy_add_x_forwarded_for;
            # Ask upstream for uncompressed content so sub_filter can inspect it
            proxy_set_header    Accept-Encoding identity;
            proxy_buffering     off;
            proxy_read_timeout  3600;
            proxy_send_timeout  3600;

            # Strip the ingress path from HTML/JS responses so the browser never
            # sees it in the URL bar (ytptube's JS calls history.replaceState with
            # YTP_BASE_PATH on startup; removing it here keeps the URL clean).
            # Requests the JS then makes to bare paths (e.g. /api/...) are caught
            # by the rewrite above and the ingress prefix is added back server-side.
            sub_filter_once  off;
            sub_filter_types text/html application/javascript text/javascript;
            sub_filter       '${INGRESS_ENTRY}/' '/';
        }
    }

    # HA ingress — ingress entry read from X-Ingress-Path header per request
    server {
        listen 8099;

        location / {
            rewrite             ^(.*)$ $http_x_ingress_path$1 break;
            proxy_pass          http://127.0.0.1:8081;
            proxy_http_version  1.1;
            proxy_set_header    Upgrade         $http_upgrade;
            proxy_set_header    Connection      $connection_upgrade;
            proxy_set_header    Host            $http_host;
            proxy_set_header    X-Real-IP       $remote_addr;
            proxy_set_header    X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header    X-Ingress-Path  $http_x_ingress_path;
            proxy_buffering     off;
            proxy_read_timeout  3600;
            proxy_send_timeout  3600;
        }
    }
}
