{
  "name": "SearXNG w/ MCP",
  "version": "2026.5.5-d3566fe8a",
  "slug": "searxng_with_mcp",
  "description": "SearXNG is a metasearch engine. Adds OvertliDS/mcp-searxng-enhanced endpoint for llama.cpp, Claude code, etc. ",
  "url": "https://github.com/jdeath/homeassistant-addons",
  "environment": {
    "ODS_CONFIG_PATH": "/etc/searxng/ods_config.json",
    "SEARXNG_ENGINE_API_BASE_URL": "http://0.0.0.0:8080/search",
    "MCP_HTTP_HOST": "0.0.0.0",
    "MCP_HTTP_PORT": "8081"
  },
  "map": [
    {
      "type": "addon_config",
      "read_only": false,
      "path": "/etc/searxng"
    }
  ],
  "hassio_api": true,
  "init": false,
  "options": {
    "set_base_url_for_ingress": true
  },
  "schema": {
    "set_base_url_for_ingress": "bool"
  },
  "ports": {
    "8080/tcp": 8080,
    "8081/tcp": 8081
  },
  "ports_description": {
    "8080/tcp": "Web interface http",
    "8081/tcp": "MCP Server interface http"
  },
  "ingress": true,
  "ingress_port": 8080,
  "panel_icon": "mdi:magnify",
  "arch": [
    "aarch64",
    "amd64"
  ]
}
